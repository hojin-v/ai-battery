{
  "name": "ai-battery",
  "version": "0.1.17",
  "description": "Tiny terminal battery meter for local Codex and Claude Code usage.",
  "type": "module",
  "keywords": [
    "ai",
    "battery",
    "codex",
    "claude",
    "statusline",
    "tui",
    "usage"
  ],
  "bin": {
    "ai-battery": "bin/ai-battery.js",
    "ai-battery-hud": "bin/ai-battery-hud.js",
    "ai-battery-run": "bin/ai-battery-run",
    "ai-battery-run-win": "bin/ai-battery-run-win.js",
    "claudex-battery": "bin/ai-battery.js",
    "claudex-battery-hud": "bin/ai-battery-hud.js",
    "claudex-battery-run": "bin/ai-battery-run"
  },
  "files": [
    "bin/ai-battery.js",
    "bin/ai-battery-run",
    "bin/ai-battery-run-win.js",
    "bin/terminal-compositor.js",
    "bin/ai-battery-hud",
    "bin/ai-battery-hud.js",
    "bin/ai-battery-macos-status.applescript",
    "bin/ai-battery-hud.ps1",
    "lib/**/*.js",
    "lib/**/*.ps1",
    "scripts/windows-rowpty-smoke.ps1",
    "scripts/windows-fullscreen-smoke.mjs",
    "scripts/wsl-windows-rowpty-smoke.sh",
    "vendor/rowpty/RowPty.cs",
    "docs/*.svg",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/ai-battery.js",
    "sync:rowpty": "node ./scripts/sync-rowpty.mjs",
    "smoke:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/windows-rowpty-smoke.ps1",
    "smoke:composite": "node ./scripts/windows-fullscreen-smoke.mjs",
    "smoke:fullscreen": "node ./scripts/windows-fullscreen-smoke.mjs --native",
    "smoke:wsl-win": "bash ./scripts/wsl-windows-rowpty-smoke.sh",
    "check": "node --check ./bin/ai-battery.js && node --check ./bin/ai-battery-hud.js && node --check ./bin/ai-battery-run-win.js && node --check ./lib/hud/launcher.js && node --check ./lib/platforms/windows/codex-runner.js && node --test",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xterm/headless": "6.0.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hojin-v/ai-battery.git"
  },
  "bugs": {
    "url": "https://github.com/hojin-v/ai-battery/issues"
  },
  "homepage": "https://github.com/hojin-v/ai-battery#readme"
}
